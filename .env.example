DATABASE_URL=postgresql://saathi:saathi@postgres:5432/saathi
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
# Managed Kafka (e.g. Aiven) deployment: switch these 5 instead of the plaintext
# default above. Leave KAFKA_SECURITY_PROTOCOL=PLAINTEXT for local Docker Compose.
# KAFKA_BOOTSTRAP_SERVERS=your-service-name.aivencloud.com:port
# KAFKA_SECURITY_PROTOCOL=SASL_SSL
# KAFKA_SASL_MECHANISM=PLAIN
# KAFKA_SASL_USERNAME=avnadmin
# KAFKA_SASL_PASSWORD=...
# KAFKA_SSL_CAFILE=./certs/aiven-ca.pem
GEMINI_API_KEY=...
BUYER_TOKEN=buyer-demo-token
ADMIN_TOKEN=admin-demo-token
WORKSHOP_TOKENS_JSON={"token-ws-1": 1, "token-ws-2": 2, "token-ws-3": 3, "token-ws-4": 4, "token-ws-5": 5, "token-ws-6": 6, "token-factory": 99}
UPLOAD_DIRECTORY=./uploads
